"""
Brain-Mimetic Triple Memory System -- Proper Memory Redefinition (2026-06)

This is the structural redefinition of "memory" as requested.

Previous attempts (memory_as_primary flag + trainer heuristics) were superficial.
This time we define memory as three distinct, brain-inspired components that
actively participate in and influence the recurrent thinking process at every step,
not as passive storage or occasional rehearsal buffers.

Brain-inspired mapping (PFC / Global Workspace / Hippocampus / Attractor networks + Predictive Cortex analog):

1. ActiveWorkingMemory (Prefrontal Cortex + Global Workspace analog)
   - Fast, capacity-limited, actively manipulated "current thoughts in progress".
   - Multiple parallel workspace streams that can be attended, updated, and broadcast.
   - This is where the "live thinking" happens. It influences the main latent state strongly and immediately.
   - Now enhanced: runs data-grounded mental simulations (K trajectories) whose evolution is scored partly by how well they align with predicted data dynamics.

2. StabilizingAttractorMemory (Cortical attractor + Hippocampal CA3-like)
   - Slow, depth-wise stabilization dynamics.
   - Provides monotonic pressure toward better states over recurrence steps.
   - Acts as a "long-term thinking" bias that pulls the fast working memory toward coherent, improved attractors.
   - Now data-intuition aware: attractor basins are shaped not only by internal coherence but by alignment with predicted plausible data states (surprise signal modulates pull strength).

3. ProvenanceEpisodicMemory (Hippocampal binding + Source monitoring)
   - Maintains causal history, source grounding, and binding between thoughts and origins.
   - Enables verification, "why" reasoning, and protection against drift or hallucinated thoughts.
   - Influences by gating or modulating updates based on provenance strength and consistency.

4. Predictive Data Intuition (integrated predictive world model signal)
   - Lightweight JEPA-style predictor that, from the current triple memory state, forecasts the "next plausible data-grounded embedding".
   - Produces a continuous **surprise / prediction error** signal.
   - This signal is the primary mechanism for building genuine "데이터에 대한 직관".
   - It modulates:
     - Which of the K mental simulations survive and how they evolve (Titans/ATLAS-style surprise-driven selection)
     - The strength and direction of attractor stabilization (high surprise states get stronger corrective pull or exploratory boost)
     - What gets strongly bound into provenance (only high-value, high-surprise events)
   - Training uses next-embedding prediction + lightweight regularizer (SIGReg-inspired) so the latent space learns to encode data dynamics without collapse.
   - Causal sensitivity diagnostics (intervention consistency, what-if coherence, surprise-causal correlation) are required accompanying evidence per the 2026-06 RI necessary conditions SSOT.

Key principle:
These components are not "read from" occasionally.
They are the primary recurrent state carriers.
The hybrid block / fast recurrence becomes a thin "perception-action" interface
that reads from this memory system and writes back into it every micro-step,
with learned influence gates.

The Predictive Data Intuition signal ensures the entire system develops an internal sense of what the data "is like" and "how it tends to evolve", rather than only manipulating abstract thoughts.

This directly addresses the substrate doubt:
  Previous "thinking engine" (tight micro-step hybrid) was trying to do too much
  while memory was a side participant. Now memory IS the thinker, structured in brain-like roles,
  with an explicit mechanism for developing data intuition via prediction error and surprise.
"""

from __future__ import annotations
from dataclasses import dataclass
from typing import Optional, Dict, Any
import torch
import torch.nn.functional as F
from torch import nn

from ..norm import RMSNorm


@dataclass
class TripleMemoryState:
    """The primary recurrent state carried across thinking steps."""
    working_memory: torch.Tensor          # (B, n_streams, d) -- ActiveWorkingMemory
    attractor_state: torch.Tensor         # (B, d) -- StabilizingAttractorMemory
    provenance_register: torch.Tensor     # (B, d) -- ProvenanceEpisodicMemory
    step_count: torch.Tensor              # (B,) -- for depth conditioning


class ActiveWorkingMemory(nn.Module):
    """
    PFC + Global Workspace style.
    Fast, multi-stream workspace that actively manipulates current thoughts.
    This is the "fast thinking" part of memory.

    Now enhanced for brain-mimetic GRAM/PTRM:
    It can evolve multiple trajectories (mental simulations) in parallel.
    """
    def __init__(self, d_model: int, n_streams: int = 4, n_heads: int = 4):
        super().__init__()
        self.d_model = d_model
        self.n_streams = n_streams
        self.streams = nn.Parameter(torch.randn(n_streams, d_model) * 0.02)
        self.update = nn.Linear(d_model * 2, d_model)
        self.norm = RMSNorm(d_model)

    def forward(self, current_latent: torch.Tensor, influence: Optional[torch.Tensor] = None) -> torch.Tensor:
        b = current_latent.shape[0]
        ws = self.streams.unsqueeze(0).expand(b, -1, -1)
        combined = torch.cat([current_latent.mean(dim=1, keepdim=True).expand(-1, self.n_streams, -1), ws], dim=-1)
        update = torch.sigmoid(self.update(combined))
        new_ws = ws * (1 - update) + current_latent.mean(dim=1, keepdim=True) * update
        return self.norm(new_ws)

    def evolve_trajectories(
        self,
        trajectories: torch.Tensor,   # (B, K, d) -- K mental simulations
    ) -> torch.Tensor:
        """
        Evolve K trajectories through the working memory update rule.
        Each trajectory is treated as a 'thought' being actively manipulated.
        """
        b, k, d = trajectories.shape
        # Treat each trajectory as a separate 'stream' for update purposes
        # Simple but effective: project each trajectory through the same update logic
        expanded = trajectories  # (B, K, d)
        # Use mean of current working memory as context (or we can make it richer later)
        # Defensive for light/native 72 mode where effective K can be 1
        effective_k = expanded.size(1) if expanded.dim() >= 2 else k
        context = expanded.mean(dim=1, keepdim=True).expand(-1, effective_k, -1)
        combined = torch.cat([context, expanded], dim=-1)
        update = torch.sigmoid(self.update(combined))
        new_trajs = expanded * (1 - update) + context * update
        return self.norm(new_trajs)


class StabilizingAttractorMemory(nn.Module):
    """
    Cortical attractor + slow stabilization.
    Provides depth-wise monotonic pull toward better states.
    This is the "slow, improving thinking" part of memory.
    """
    def __init__(self, d_model: int):
        super().__init__()
        self.d_model = d_model
        self.attractor_proj = nn.Linear(d_model, d_model)
        self.stability_gate = nn.Linear(d_model * 2, 1)
        self.norm = RMSNorm(d_model)

    def forward(self, current_state: torch.Tensor, history: torch.Tensor, depth: int) -> torch.Tensor:
        # Simple attractor: pull current toward a smoothed better version of history
        target = self.attractor_proj(history)
        gate_input = torch.cat([current_state, target], dim=-1)
        gate = torch.sigmoid(self.stability_gate(gate_input))
        # Stronger pull at greater depth (monotonic pressure)
        depth_factor = min(1.0, depth / 8.0) * 0.3
        new_state = current_state * (1 - gate * depth_factor) + target * (gate * depth_factor)
        return self.norm(new_state)


class ProvenanceEpisodicMemory(nn.Module):
    """
    Hippocampal-style binding + source monitoring.
    Tracks where thoughts came from and their causal support.
    Influences thinking by providing verification/modulation signals.
    """
    def __init__(self, d_model: int):
        super().__init__()
        self.d_model = d_model
        self.bind_proj = nn.Linear(d_model * 2, d_model)
        self.consistency_gate = nn.Linear(d_model, 1)
        self.norm = RMSNorm(d_model)

    def forward(self, current_state: torch.Tensor, source_signal: Optional[torch.Tensor] = None) -> torch.Tensor:
        if source_signal is None:
            source_signal = current_state
        bound = self.bind_proj(torch.cat([current_state, source_signal], dim=-1))
        consistency = torch.sigmoid(self.consistency_gate(bound))
        # High consistency strengthens the state, low consistency dampens drift
        new_state = current_state * (0.7 + 0.3 * consistency) + bound * (0.3 * consistency)
        return self.norm(new_state)


class PredictiveDataIntuition(nn.Module):
    """
    Lightweight predictive world model that gives the triple memory system
    genuine "data intuition".

    It predicts the next plausible data-grounded state from the current
    memory configuration and produces a surprise signal (prediction error).
    This signal is used to shape mental simulations, attractor dynamics,
    and provenance binding -- exactly the mechanism for building an
    internal sense of "what the data is like and how it tends to evolve".

    Design inspired by:
    - V-JEPA 2 / LLM-JEPA (latent embedding prediction over reconstruction)
    - LeWorldModel 2026 (stable end-to-end + SIGReg-style regularization)
    - Titans/ATLAS (surprise = prediction error as first-class memory signal)
    - Equilibrium Reasoners (prediction error helps shape reliable attractors)
    """

    def __init__(self, d_model: int, pred_hidden: int = None):
        super().__init__()
        self.d_model = d_model
        hidden = pred_hidden or d_model * 2

        # JEPA-style predictor: predicts next data-relevant state from triple memory
        self.predictor = nn.Sequential(
            RMSNorm(d_model * 3),
            nn.Linear(d_model * 3, hidden),
            nn.GELU(),
            nn.Linear(hidden, d_model),
        )

        # Learned weighting for surprise
        self.surprise_gate = nn.Linear(d_model, 1)

        # Anti-collapse regularizer (lightweight SIGReg-style projection)
        self.regularizer_proj = nn.Linear(d_model, d_model, bias=False)

    def _ensure_same_device(self, tensor: torch.Tensor):
        device = tensor.device
        dtype = tensor.dtype
        if next(self.parameters()).device != device:
            self.to(device=device, dtype=dtype)

    def forward(
        self,
        working: torch.Tensor,
        attractor: torch.Tensor,
        provenance: torch.Tensor,
    ) -> tuple[torch.Tensor, torch.Tensor]:
        """
        Predict next plausible data state and return surprise.
        Returns:
            pred_next: (B, d)
            surprise: (B, 1)  -- higher = more surprising/unexpected from learned data model
        """
        self._ensure_same_device(working)
        device = working.device
        dtype = working.dtype

        def _pool_bd(x):
            x = x.to(device, dtype)
            if x.dim() == 2:
                return x  # (B, d) already
            if x.dim() == 3:
                return x.mean(dim=1)
            if x.dim() > 3:
                # collapse all middle dims
                return x.flatten(1, -2).mean(dim=1)
            return x.unsqueeze(0) if x.dim() == 1 else x

        w = _pool_bd(working)
        a = _pool_bd(attractor)
        p = _pool_bd(provenance)

        joint = torch.cat([w, a, p], dim=-1)
        pred = self.predictor(joint)

        # Surprise as normalized prediction error (core "data intuition" signal)
        error = (pred - w).pow(2).mean(dim=-1, keepdim=True)
        surprise = torch.sigmoid(self.surprise_gate(w)) * error

        return pred, surprise

    def compute_prediction_loss(
        self,
        working: torch.Tensor,
        attractor: torch.Tensor,
        provenance: torch.Tensor,
        target: torch.Tensor = None,   # optional explicit target (for stronger supervision)
        reg_weight: float = 0.01,
    ) -> dict:
        """
        Training loss for the data intuition predictor (JEPA-style).
        Returns dict with 'pred_loss', 'reg_loss', 'total_loss'.
        """
        self._ensure_same_device(working)
        device = working.device
        dtype = working.dtype

        def _pool_bd(x):
            x = x.to(device, dtype)
            if x.dim() == 2:
                return x  # (B, d) already
            if x.dim() == 3:
                return x.mean(dim=1)
            if x.dim() > 3:
                # collapse all middle dims
                return x.flatten(1, -2).mean(dim=1)
            return x.unsqueeze(0) if x.dim() == 1 else x

        w = _pool_bd(working)
        a = _pool_bd(attractor)
        p = _pool_bd(provenance)

        joint = torch.cat([w, a, p], dim=-1)
        pred = self.predictor(joint)

        if target is None:
            target = w  # self-prediction (common in JEPA-style for world models)

        pred_loss = F.mse_loss(pred, target)

        # Lightweight regularization to keep latents well-behaved (anti-collapse)
        reg = self.regularizer_proj(pred)
        reg_loss = (reg.pow(2).mean() - 1.0).clamp(min=0) * reg_weight

        total = pred_loss + reg_loss

        return {
            "pred_loss": pred_loss,
            "reg_loss": reg_loss,
            "total_loss": total,
            "pred": pred.detach(),
        }


class BrainMimeticTripleMemory(nn.Module):
    """
    The properly redefined memory system.
    These three components together ARE the recurrent thinker.

    At every recurrence step:
    - WorkingMemory actively updates the current live thoughts.
    - AttractorMemory applies slow stabilization pull.
    - ProvenanceMemory provides causal grounding and verification influence.

    The main latent (from hybrid block or thin interface) is now secondary --
    it mostly reads from and writes into this triple memory.
    """

    def __init__(self, d_model: int, n_workspace_streams: int = 4):
        super().__init__()
        self.d_model = d_model
        self.working = ActiveWorkingMemory(d_model, n_streams=n_workspace_streams)
        self.attractor = StabilizingAttractorMemory(d_model)
        self.provenance = ProvenanceEpisodicMemory(d_model)

        # Predictive Data Intuition -- the mechanism for "데이터에 대한 직관"
        # Runs lightweight JEPA-style prediction on the triple state and produces surprise.
        self.data_intuition = PredictiveDataIntuition(d_model)
        self.data_intuition_enabled = True
        self.data_intuition_ablation_zero = False

        # Long-term persistent memory layer (Raven + LM2 + MSA + surprise integration)
        # This completes the multi-scale memory for the evolved BMSAM design.
        self.long_term_memory = None
        self.long_term_memory_enabled = False
        self.long_term_memory_ablation_zero = False
        self._latest_long_term_slots = None
        self._cached_long_term_mask = None
        self._cached_long_term_slots = None

        # === Best-State Architecture (2026-06): Chunked Slow Memory Adapter ===
        # Per LaCT + ATLAS Omega: the expensive slow memory updates should be chunked,
        # not per-micro or small-stride. This adapter buffers context + surprise and
        # triggers high-quality commits only at coherent boundaries.
        self.chunked_slow_adapter = None
        self.chunked_slow_enabled = False
        self.chunked_slow_ablation_zero = False

        # Influence gates (learned) -- how much each memory component affects the main latent
        self.working_influence = nn.Linear(d_model, 1)
        self.attractor_influence = nn.Linear(d_model, 1)
        self.provenance_influence = nn.Linear(d_model, 1)
        self.intuition_influence = nn.Linear(1, 1)  # how much surprise (scalar) modulates the output -- fixed for data intuition path
        self.long_term_read_influence = nn.Linear(d_model, 1)
        self.long_term_summary_influence = nn.Linear(d_model, 1)  # final one-body readout feels the slow persistent memory

        # Light eval mode flag (for safe native full-stack 72 heldout without freeze)
        # When True: K forced to 1, all long-term writes disabled, heavy paths minimized
        self._light_eval_mode = False

    def _ensure_same_device(self, tensor: torch.Tensor):
        """Force this module + relevant state onto the device of the given tensor."""
        device = tensor.device
        dtype = tensor.dtype
        if next(self.parameters()).device != device:
            self.to(device=device, dtype=dtype)

    def set_light_eval_mode(self, enabled: bool = True):
        """
        Activate ultra-safe light evaluation mode for native full-stack 72 heldout.
        This is the primary defense against system freeze/OOM during heavy brain memory eval.

        Effects:
        - Forces stochastic_k = 1 (no K-trajectory mental simulation breadth)
        - Disables ALL long-term memory write / incremental consolidation paths
        - Keeps long-term read (for native participation feel) but read-only
        - Skips heavy surprise-driven write logic
        - compute_data_intuition_loss returns zero (no training loss during pure eval)
        """
        self._light_eval_mode = bool(enabled)
        if enabled:
            # Force minimal compute
            if hasattr(self, 'stochastic_k'):
                self.stochastic_k = 1
            # Long-term: allow read for "native" signal, but block every write path
            self.long_term_memory_enabled = True  # keep attached
            # Explicit write guard flag (consulted in step and long_term paths)
            self._long_term_write_disabled = True
            print("[Light Eval Mode] BrainMimeticTripleMemory entered SAFE mode (K=1, long-term writes BLOCKED)")
        else:
            self._long_term_write_disabled = False
            print("[Light Eval Mode] BrainMimeticTripleMemory exited safe mode")

    def set_native_eval_mode(self, enabled: bool = True, router_cache_interval: int = 4):
        """
        Real native push mode (option 2): Keep actual brain memory participation
        during 72 heldout (no full bypass), but make each participation as cheap
        and stable as possible.

        This is different from previous "fast" modes that risked skipping participation.
        Goal: per-step (or near per-step) native influence without freezing or 10+ min runtimes.
        """
        self._native_eval_mode = bool(enabled)
        if enabled:
            self._light_eval_mode = True
            if hasattr(self, 'stochastic_k'):
                self.stochastic_k = 1
            self._long_term_write_disabled = True

            # Propagate router optimization (biggest cost saver for native long-term)
            if self.long_term_memory is not None and hasattr(self.long_term_memory, 'enable_fast_eval'):
                self.long_term_memory.enable_fast_eval(True, cache_interval=router_cache_interval)

            print(f"[Native Eval Mode] Real native participation enabled (router cache_interval={router_cache_interval})")

    def fast_native_step(self, current_latent, memory_state, depth, source_signal=None):
        """Thin wrapper that uses all the fast flags set by set_fast_native_eval.
        Can be extended later with more aggressive internal shortcuts while still doing the core native influence.
        """
        return self.step(current_latent, memory_state, depth, source_signal)

    def set_ultra_fast_measurement_mode(self, enabled: bool = True, brain_step_interval: int = 2, long_term_stride: int = 4):
        """
        1번 extreme push: Measurement-only ultra-aggressive mode.
        Goal: Make 4~8 case native 72 heldout finish in minutes instead of hours,
        while still having *real* brain memory (triple + long-term + surprise) participate
        on selected micro-steps (not a full bypass).

        Cuts (measurement only):
        - brain step called only every N micro-steps (interval)
        - long-term router read even sparser
        - extra internal caches + reduced data_intuition frequency
        """
        self._ultra_fast_measurement = bool(enabled)
        if enabled:
            self._light_eval_mode = True
            self._native_eval_mode = True
            self._long_term_write_disabled = True
            if hasattr(self, 'stochastic_k'):
                self.stochastic_k = 1
            self._long_term_read_stride = int(long_term_stride)
            self._brain_step_interval = int(brain_step_interval)
            # Push router cache harder + mark for 1번 compile-friendly path
            if self.long_term_memory is not None and hasattr(self.long_term_memory, 'enable_fast_eval'):
                self.long_term_memory.enable_fast_eval(True, cache_interval=max(4, long_term_stride))
            # Tell the router we are in ultra measurement (allows .item() avoidance for better dynamo capture)
            if hasattr(self.long_term_memory, 'router') and self.long_term_memory.router is not None:
                self.long_term_memory.router._ultra_fast_measurement = True
            print(f"[ULTRA FAST MEASUREMENT] brain_step_interval={brain_step_interval}, lt_stride={long_term_stride}")

    def step(
        self,
        current_latent: torch.Tensor,
        memory_state: TripleMemoryState,
        depth: int,
        source_signal: Optional[torch.Tensor] = None,
    ) -> tuple[torch.Tensor, TripleMemoryState]:
        # === DEBUG for native B=8 expand error pinpointing ===
        if getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False):
            print(f"[DEBUG step entry] current_latent.shape={current_latent.shape}, B={current_latent.shape[0]}, depth={depth}")
        # Always sync everything to the input device first -- this is the main fix for "computer stops / device error"
        self._ensure_same_device(current_latent)

        device = current_latent.device
        dtype = current_latent.dtype

        memory_state.working_memory = memory_state.working_memory.to(device=device, dtype=dtype)
        memory_state.attractor_state = memory_state.attractor_state.to(device=device, dtype=dtype)
        memory_state.provenance_register = memory_state.provenance_register.to(device=device, dtype=dtype)

        # === Long-term Persistent Memory Read (using first-class SparseGatedLongTermMemory) ===
        long_term_read = None
        self._cached_long_term_mask = None
        self._cached_long_term_slots = None

        fast = getattr(self, '_fast_native_eval', False)

        # === 직관-driven 최적화 (A): Long-term router 빈도 대폭 감소 ===
        # native full-stack이라도 "매 micro-step마다 무거운 router를 부르는 것"은 eval에서 치명적.
        # stride 스텝마다 한 번만 full long-term read (router + surprise)를 하고,
        # 그 외 스텝에서는 long-term block을 완전히 스킵.
        # -> router 비용을 1/stride 로 줄이면서도, 주기적으로 진짜 native long-term influence는 받음.
        # (인간 뇌도 매 순간 hippocampus full activation을 하진 않는다)
        do_long_term_this_step = True
        if fast:
            stride = getattr(self, '_long_term_read_stride', 3)  # 직관: 3이 안전하면서 효과 좋은 값
            if not hasattr(self, '_long_term_read_counter'):
                self._long_term_read_counter = 0
            self._long_term_read_counter += 1
            if self._long_term_read_counter % stride != 0:
                do_long_term_this_step = False

        if (self.long_term_memory is not None and 
            getattr(self, 'long_term_memory_enabled', False) and 
            not getattr(self, 'long_term_memory_ablation_zero', False) and
            do_long_term_this_step):   # <- 이 조건이 핵심 (A 최적화)

            pooled_query = current_latent.mean(dim=1) if current_latent.dim() == 3 else current_latent
            current_surprise = None

            if (getattr(self, 'data_intuition_enabled', False) and 
                not getattr(self, 'data_intuition_ablation_zero', False)):

                native_eval = getattr(self, '_native_eval_mode', False)

                if native_eval:
                    # A-2: Much more aggressive reduction in native mode
                    # Compute surprise only every N steps (default 6~8) to cut MLP cost
                    surprise_interval = getattr(self, '_native_surprise_interval', 6)
                    if not hasattr(self, '_native_surprise_cache') or self._native_surprise_cache is None or (depth % surprise_interval == 0):
                        _, current_surprise = self.data_intuition(
                            working=memory_state.working_memory,
                            attractor=memory_state.attractor_state,
                            provenance=memory_state.provenance_register,
                        )
                        self._native_surprise_cache = current_surprise
                    else:
                        current_surprise = self._native_surprise_cache
                elif not fast or not hasattr(self, '_last_surprise') or self._last_surprise is None:
                    _, current_surprise = self.data_intuition(
                        working=memory_state.working_memory,
                        attractor=memory_state.attractor_state,
                        provenance=memory_state.provenance_register,
                    )
                    if fast:
                        self._last_surprise = current_surprise
                else:
                    current_surprise = self._last_surprise

            try:
                read_signal, mask, slots = self.long_term_memory(
                    query=pooled_query,
                    surprise=current_surprise,
                )
                long_term_read = read_signal
                self._cached_long_term_mask = mask
                self._cached_long_term_slots = slots
            except Exception:
                long_term_read = None
                self._cached_long_term_mask = None
                self._cached_long_term_slots = None

            if long_term_read is not None:
                if long_term_read.dim() == 3:
                    proj_in = long_term_read.mean(dim=1)
                else:
                    proj_in = long_term_read
                lt_influence = torch.sigmoid(self.long_term_read_influence(proj_in))
                long_term_weight = 0.4 + 0.3 * lt_influence
                if current_latent.dim() == 3:
                    current_latent = current_latent + long_term_read.unsqueeze(1) * long_term_weight.unsqueeze(-1).unsqueeze(-1)
                else:
                    current_latent = current_latent + long_term_read * long_term_weight.unsqueeze(-1)

        b = current_latent.shape[0]

        # === Brain-Mimetic Stochastic Sampling (if enabled) ===
        use_stochastic = hasattr(self, 'stochastic_sampler') and self.stochastic_sampler is not None

        # Defensive: in light/native 72 mode, force minimal stochastic even if sampler exists
        if getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False):
            use_stochastic = False  # prevent K>1 dimension issues in measurement

        if use_stochastic:
            sampler = self.stochastic_sampler

            # Long-term memory context is now available *before* mental simulation
            # so that K trajectories can be generated with awareness of long-term memory + surprise.
            long_term_context = long_term_read if 'long_term_read' in locals() else None

            # === LIGHT EVAL MODE GUARD (critical for non-freezing 72 heldout) ===
            if getattr(self, '_light_eval_mode', False):
                k = 1  # hard force minimal mental simulation -- biggest memory saver
            else:
                k = getattr(self, 'stochastic_k', 4)

            # 1. Generate K structured trajectories (mental simulations)
            # Long-term context (when present) biases the hypothesis generation.
            trajectories = sampler.sample_trajectories(
                current_working_memory=memory_state.working_memory,
                attractor_state=memory_state.attractor_state,
                provenance_state=memory_state.provenance_register,
                k=k,
                long_term_context=long_term_context,
            )  # (B, K, d)

            # 2. Evolve the K trajectories through Working Memory (active manipulation)
            evolved_trajs = self.working.evolve_trajectories(trajectories)

            # 3. Score the evolved trajectories using Attractor + Provenance + Data Intuition (surprise)
            intuition_surprise = None
            if getattr(self, 'data_intuition_enabled', False) and not getattr(self, 'data_intuition_ablation_zero', False):
                if getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False):
                    print(f"[DEBUG expand] evolved_trajs.shape={evolved_trajs.shape} (in data_intuition path)")
                _, traj_surprise = self.data_intuition(
                    working=evolved_trajs,
                    attractor=memory_state.attractor_state.unsqueeze(1).expand(-1, evolved_trajs.size(1), -1),
                    provenance=memory_state.provenance_register.unsqueeze(1).expand(-1, evolved_trajs.size(1), -1),
                )
                intuition_surprise = traj_surprise.squeeze(-1)  # (B, K)

            best_trajectory = sampler.select_best_trajectory(
                trajectories=evolved_trajs,
                attractor_state=memory_state.attractor_state,
                provenance_state=memory_state.provenance_register,
                intuition_surprise=intuition_surprise,
                long_term_context=long_term_context,
            )  # (B, d)

            # === Incremental Long-term Memory Consolidation (during thinking) ===
            # High-surprise trajectories during mental simulation are immediately given a chance
            # to softly write into long-term memory. This creates online, surprise-driven
            # consolidation instead of only end-of-step batch write (very much in the spirit
            # of Titans/ATLAS surprise-driven memory + EM-LLM episodic thinking).
            #
            # LIGHT EVAL MODE: completely disable this write path (biggest freeze risk during 72 heldout)
            light_mode = getattr(self, '_light_eval_mode', False) or getattr(self, '_long_term_write_disabled', False)
            if (not light_mode and
                self.long_term_memory is not None and 
                getattr(self, 'long_term_memory_enabled', False) and 
                not getattr(self, 'long_term_memory_ablation_zero', False) and
                intuition_surprise is not None and
                hasattr(self.long_term_memory, 'write')):

                # Find trajectories with significantly above-average surprise
                avg_surprise = intuition_surprise.mean()
                high_surprise_mask = intuition_surprise > (avg_surprise + 0.5 * avg_surprise)

                if high_surprise_mask.any():
                    # For high-surprise trajectories, perform a soft preview write
                    # using the evolved trajectory as the update signal.
                    high_surprise_trajs = evolved_trajs[:, high_surprise_mask, :].mean(dim=1)  # (B, d)
                    high_surprise_mask_1d = high_surprise_mask.any(dim=1).float().unsqueeze(-1)  # rough aggregate mask

                    try:
                        # Re-use the current long-term mask if available, otherwise let the router decide
                        if self._cached_long_term_mask is not None:
                            write_mask = self._cached_long_term_mask * high_surprise_mask_1d
                        else:
                            _, write_mask, _ = self.long_term_memory(query=high_surprise_trajs)

                        _ = self.long_term_memory.write(
                            update_signal=high_surprise_trajs,
                            mask=write_mask,
                            surprise=intuition_surprise[:, high_surprise_mask].mean(dim=1, keepdim=True),
                        )
                    except Exception:
                        pass  # Never let incremental consolidation break the main recurrence

            # 4. Update working memory with the best trajectory while preserving some diversity
            # Put the best trajectory as the "main" signal, and inject small variations of the other good trajectories
            # into the different streams for richer representation.
            new_working = memory_state.working_memory.clone()
            # === DEBUG: pinpoint expand error in native B=8 72 ===
            if getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False):
                print(f"[DEBUG expand] best_trajectory.shape={best_trajectory.shape}, n_streams={self.working.n_streams}, working_memory.shape={memory_state.working_memory.shape}")
            best_expanded = best_trajectory.unsqueeze(1).expand(-1, self.working.n_streams, -1)
            new_working = 0.7 * new_working + 0.3 * best_expanded

            # Inject mild diversity from other trajectories into individual streams (keeps exploration alive)
            if k > 1:
                # Simple: spread some of the other trajectories across streams
                other_trajs = evolved_trajs  # (B, K, d)
                for s in range(min(self.working.n_streams, k)):
                    mix = 0.15
                    new_working[:, s] = (1 - mix) * new_working[:, s] + mix * other_trajs[:, s % k]

            new_working = self.working.norm(new_working)

            # If long-term memory was read, also gently inject it into the working memory streams
            # so that the K mental simulations themselves are shaped by long-term context + surprise.
            if long_term_read is not None and 'new_working' in locals():
                if getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False):
                    print(f"[DEBUG expand] long_term_read.shape={long_term_read.shape}, new_working.size(1)={new_working.size(1)}")
                lt_for_streams = long_term_read.unsqueeze(1).expand(-1, new_working.size(1), -1)
                # Surprise-modulated injection into the active workspace (brain-mimetic)
                stream_influence = 0.15 + 0.1 * lt_influence.unsqueeze(-1)  # from earlier calculation
                new_working = new_working + lt_for_streams * stream_influence.unsqueeze(-1) * 0.6

            # Primary signal for modulating the outer latent is still the best trajectory
            working_signal = best_trajectory.unsqueeze(1)
        else:
            # Original path (no deep stochastic)
            new_working = self.working(current_latent, influence=None)
            working_signal = new_working.mean(dim=1, keepdim=True)

        working_effect = torch.sigmoid(self.working_influence(working_signal.mean(dim=1)))

        # === Attractor (slow stabilization) -- now explicitly multi-scale via long-term + surprise ===
        # This is the key tightening: the "slow thinking" layer (attractor) is shaped by
        # long-term memory context (read with surprise bias) and current data intuition surprise.
        # High surprise -> stronger long-term influence on where the slow stabilization pulls toward.
        attractor_history = working_signal.mean(dim=1)

        # Robust long-term context: long_term_read is computed early (before stochastic branch)
        # and is available in both stochastic and non-stochastic paths when long-term is enabled.
        long_term_ctx_for_attractor = long_term_read if (long_term_read is not None) else None

        new_attractor = self._stabilize_attractor(
            current_attractor=memory_state.attractor_state,
            attractor_history=attractor_history,
            depth=depth,
            long_term_context=long_term_ctx_for_attractor,
            surprise=(intuition_surprise.mean() if 'intuition_surprise' in locals() and intuition_surprise is not None else None),
        )
        attractor_effect = torch.sigmoid(self.attractor_influence(new_attractor))

        # === Provenance (grounding) ===
        new_provenance = self.provenance(working_signal.mean(dim=1), source_signal)
        provenance_effect = torch.sigmoid(self.provenance_influence(new_provenance))

        # Modulate the main latent with active memory influences
        modulated = current_latent
        modulated = modulated + working_signal * working_effect.unsqueeze(-1).unsqueeze(-1) * 0.4
        modulated = modulated + new_attractor.unsqueeze(1) * attractor_effect.unsqueeze(-1).unsqueeze(-1) * 0.3
        modulated = modulated + new_provenance.unsqueeze(1) * provenance_effect.unsqueeze(-1).unsqueeze(-1) * 0.3

        # === Predictive Data Intuition modulation (the "data sense" signal) ===
        if getattr(self, 'data_intuition_enabled', False) and not getattr(self, 'data_intuition_ablation_zero', False):
            _, final_surprise = self.data_intuition(
                working=working_signal,
                attractor=new_attractor,
                provenance=new_provenance,
            )
            fs = final_surprise
            if fs.dim() > 1:
                fs = fs.mean(dim=1, keepdim=True) if fs.size(-1) != 1 else fs
            else:
                fs = fs.view(-1, 1)
            intuition_effect = torch.sigmoid(self.intuition_influence(fs))

            # Use the predictor to generate a data-plausible correction direction
            data_correction = self.data_intuition.predictor(
                torch.cat([working_signal.mean(dim=1), new_attractor, new_provenance], dim=-1)
            )
            # Modulate how much we trust the data intuition signal
            modulated = modulated + data_correction.unsqueeze(1) * intuition_effect.unsqueeze(-1).unsqueeze(-1) * 0.12

        new_state = TripleMemoryState(
            working_memory=new_working if use_stochastic else new_working,
            attractor_state=new_attractor,
            provenance_register=new_provenance,
            step_count=memory_state.step_count + 1,
        )

        # === Long-term Persistent Memory Write (using first-class API + surprise as primary driver) ===
        # Best-state path (v2): If ChunkedSlowMemoryAdapter is active, we accumulate instead of writing every step.
        # The adapter decides when to do a real high-quality commit (chunk boundary or high surprise).
        final_surprise = None
        update_signal = modulated.mean(dim=1) if modulated.dim() == 3 else modulated

        if (self.chunked_slow_adapter is not None and 
            getattr(self, 'chunked_slow_enabled', False) and 
            not getattr(self, 'chunked_slow_ablation_zero', False)):

            # Accumulate for chunked processing (LaCT/Omega style)
            try:
                _, fs = self.data_intuition(
                    working=new_state.working_memory,
                    attractor=new_state.attractor_state,
                    provenance=new_state.provenance_register,
                )
                final_surprise = fs
            except Exception:
                final_surprise = None

            self.chunked_slow_adapter.accumulate(update_signal, final_surprise)

            if self.chunked_slow_adapter.should_commit(final_surprise):
                self.chunked_slow_adapter.commit()
                # After commit, refresh cache if possible
                if hasattr(self.long_term_memory, 'get_state'):
                    self._latest_long_term_slots = self.long_term_memory.get_state()

        elif (self.long_term_memory is not None and 
              getattr(self, 'long_term_memory_enabled', False) and 
              not getattr(self, 'long_term_memory_ablation_zero', False) and
              hasattr(self.long_term_memory, 'write')):

            # Legacy per-step / strided path (still supported for ablation and light modes)
            try:
                _, final_surprise = self.data_intuition(
                    working=new_state.working_memory,
                    attractor=new_state.attractor_state,
                    provenance=new_state.provenance_register,
                )
            except Exception:
                final_surprise = None

            mask = self._cached_long_term_mask
            if mask is None:
                _, mask, _ = self.long_term_memory(query=update_signal)

            try:
                updated_slots = self.long_term_memory.write(
                    update_signal=update_signal,
                    mask=mask,
                    surprise=final_surprise,
                )
                self._latest_long_term_slots = updated_slots
            except Exception:
                self._latest_long_term_slots = self._cached_long_term_slots
                pass

        self._cached_long_term_mask = None
        self._cached_long_term_slots = None

        # === Final one-body long-term memory summary injection (직관 tightening) ===
        # The slow persistent memory (Raven/LM2 gated slots + surprise) now has a direct,
        # small, ablatable voice in the final latent that feeds the LM head.
        # This completes the loop: everything the model ultimately outputs "feels" the data intuition
        # and the long-term memory it consolidated earlier.
        if (self.long_term_memory is not None and
            getattr(self, 'long_term_memory_enabled', False) and
            not getattr(self, 'long_term_memory_ablation_zero', False) and
            'long_term_read' in locals() and long_term_read is not None):

            # Ensure we have a surprise signal for modulation (cheap recompute if needed)
            sum_surprise = None
            if 'final_surprise' in locals() and final_surprise is not None:
                sum_surprise = final_surprise
            elif getattr(self, 'data_intuition_enabled', False) and not getattr(self, 'data_intuition_ablation_zero', False):
                try:
                    _, sum_surprise = self.data_intuition(
                        working=new_state.working_memory,
                        attractor=new_state.attractor_state,
                        provenance=new_state.provenance_register,
                    )
                except Exception:
                    pass

            summary = self._get_long_term_summary(long_term_read, surprise=sum_surprise)
            if summary is not None:
                lt_sum_infl = torch.sigmoid(self.long_term_summary_influence(summary))
                # Very light residual so one-body contract and scale are preserved
                modulated = modulated + summary.unsqueeze(1) * lt_sum_infl.unsqueeze(-1).unsqueeze(-1) * 0.08

        return modulated, new_state

    def compute_data_intuition_loss(
        self,
        memory_state: TripleMemoryState,
        target: torch.Tensor = None,
        reg_weight: float = 0.01,
    ) -> dict:
        """Convenience method for trainers to get the Predictive Data Intuition loss."""
        # Light eval mode: never compute training loss during pure 72 measurement
        if getattr(self, '_light_eval_mode', False):
            dev = next(self.parameters()).device if list(self.parameters()) else torch.device('cpu')
            return {"total_loss": torch.tensor(0.0, device=dev), "pred_loss": 0.0, "reg_loss": 0.0}

        if not getattr(self, 'data_intuition_enabled', False) or getattr(self, 'data_intuition_ablation_zero', False):
            return {"total_loss": torch.tensor(0.0, device=next(self.parameters()).device)}

        return self.data_intuition.compute_prediction_loss(
            working=memory_state.working_memory,
            attractor=memory_state.attractor_state,
            provenance=memory_state.provenance_register,
            target=target,
            reg_weight=reg_weight,
        )

    def attach_long_term_memory(self, long_term_module, enabled: bool = True):
        """
        Attach a first-class long-term memory module (preferably SparseGatedLongTermMemory).
        This turns the triple memory into a true multi-scale system:
        fast active thinking + surprise-driven long-term sparse persistent memory.
        """
        self.long_term_memory = long_term_module
        self.long_term_memory_enabled = bool(enabled)

    def set_long_term_ablation(self, enabled: bool = True, ablation_zero: bool = False):
        self.long_term_memory_enabled = bool(enabled)
        self.long_term_memory_ablation_zero = bool(ablation_zero)

    def get_latest_long_term_slots(self):
        """Returns the most recent updated long-term memory slots after a step().
        Trainers should call this after step() and persist the returned tensor into the long-term module
        if it maintains its own state.
        """
        return getattr(self, '_latest_long_term_slots', None)

    def get_long_term_state(self):
        """Returns the full persistent state of the attached long-term memory (if any).
        This enables true cross-step / cross-batch persistence of the slow memory layer.
        """
        if self.long_term_memory is not None and hasattr(self.long_term_memory, 'get_state'):
            return self.long_term_memory.get_state()
        return None

    def set_long_term_state(self, state: torch.Tensor):
        """Restore the persistent long-term memory state (e.g. from checkpoint).
        Must be called before a sequence of step() calls if you want the slow memory
        to carry knowledge across the sequence.
        """
        if self.long_term_memory is not None and hasattr(self.long_term_memory, 'set_state') and state is not None:
            self.long_term_memory.set_state(state)

    def run_causal_intervention_probe(
        self,
        current_latent: torch.Tensor,
        memory_state: TripleMemoryState,
        depth: int,
        source_signal: Optional[torch.Tensor] = None,
    ) -> dict:
        """
        Causal sensitivity diagnostic (per 2026-06 RI necessary conditions).

        Runs two parallel micro-steps:
          - Normal: full long-term memory + surprise coupling active.
          - What-if (intervention): long-term memory forcibly ablated (no read, no summary injection,
            no surprise-modulated write influence on this step).

        Returns quantitative causal impact:
          - delta_modulated_norm: L2 difference in the final latent fed to LM head
          - delta_modulated_cosine: how directionally different the output became
          - delta_surprise: change in PredictiveDataIntuition surprise signal
          - long_term_was_active: whether long-term was actually contributing before intervention

        This gives a direct number: "how much does the slow persistent memory + data intuition
        causally move the thinking?"
        """
        if not getattr(self, 'long_term_memory_enabled', False) or getattr(self, 'long_term_memory_ablation_zero', False):
            return {
                "delta_modulated_norm": 0.0,
                "delta_modulated_cosine": 0.0,
                "delta_surprise": 0.0,
                "long_term_was_active": False,
                "note": "long_term disabled or ablated -> zero causal impact by construction"
            }

        device = current_latent.device
        dtype = current_latent.dtype

        # Save stochastic sampler temporarily to make probe deterministic and shape-safe
        saved_sampler = getattr(self, "stochastic_sampler", None)
        self.stochastic_sampler = None  # force clean non-K path for diagnostic

        # Normalize everything defensively for diagnostic stability
        def _safe_pool(x, target_rank=3):
            if x is None:
                return x
            while x.dim() > target_rank:
                x = x.mean(dim=1)
            return x

        wm = _safe_pool(memory_state.working_memory)
        att = _safe_pool(memory_state.attractor_state, target_rank=2)
        prov = _safe_pool(memory_state.provenance_register, target_rank=2)
        lat = _safe_pool(current_latent)

        # --- Normal path (full system) ---
        state_normal = TripleMemoryState(
            working_memory=wm.clone(),
            attractor_state=att.clone(),
            provenance_register=prov.clone(),
            step_count=memory_state.step_count.clone(),
        )
        mod_normal, state_after_normal = self.step(
            lat.clone(), state_normal, depth, source_signal
        )

        # Compute surprise after normal step
        surprise_normal = 0.0
        if getattr(self, 'data_intuition_enabled', False) and not getattr(self, 'data_intuition_ablation_zero', False):
            try:
                _, s_n = self.data_intuition(
                    working=state_after_normal.working_memory,
                    attractor=state_after_normal.attractor_state,
                    provenance=state_after_normal.provenance_register,
                )
                surprise_normal = float(s_n.mean().detach().cpu())
            except Exception:
                pass

        # --- What-if intervention: temporarily ablate long-term memory ---
        original_ablation = getattr(self, 'long_term_memory_ablation_zero', False)
        self.long_term_memory_ablation_zero = True

        state_whatif = TripleMemoryState(
            working_memory=wm.clone(),
            attractor_state=att.clone(),
            provenance_register=prov.clone(),
            step_count=memory_state.step_count.clone(),
        )
        mod_whatif, state_after_whatif = self.step(
            lat.clone(), state_whatif, depth, source_signal
        )

        # Restore flag immediately (critical for training stability)
        self.long_term_memory_ablation_zero = original_ablation

        surprise_whatif = 0.0
        if getattr(self, 'data_intuition_enabled', False) and not getattr(self, 'data_intuition_ablation_zero', False):
            try:
                _, s_w = self.data_intuition(
                    working=state_after_whatif.working_memory,
                    attractor=state_after_whatif.attractor_state,
                    provenance=state_after_whatif.provenance_register,
                )
                surprise_whatif = float(s_w.mean().detach().cpu())
            except Exception:
                pass

        # --- Causal impact metrics (defensive pooling on outputs) ---
        mod_n = _safe_pool(mod_normal, target_rank=3)
        mod_w = _safe_pool(mod_whatif, target_rank=3)
        delta = (mod_n - mod_w).detach()
        delta_norm = float(delta.norm().cpu())
        cos_sim = torch.nn.functional.cosine_similarity(
            mod_n.flatten(), mod_w.flatten(), dim=0
        ).item()
        delta_surprise = abs(surprise_normal - surprise_whatif)

        # Restore stochastic sampler
        self.stochastic_sampler = saved_sampler

        return {
            "delta_modulated_norm": round(delta_norm, 6),
            "delta_modulated_cosine": round(1.0 - cos_sim, 6),
            "surprise_normal": round(surprise_normal, 6),
            "surprise_whatif": round(surprise_whatif, 6),
            "delta_surprise": round(delta_surprise, 6),
            "long_term_was_active": True,
        }

    # === Best-State Architecture: Lightweight update for the block's slow voice ===
    def light_update(self, current_latent: torch.Tensor, inference_mode: bool = False) -> Optional[torch.Tensor]:
        """
        Called from inside OneBodyParallelHybridBlock after the fast recurrence.
        """
        # === DEBUG for native B=8 expand error pinpointing ===
        if getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False):
            print(f"[DEBUG light_update entry] current_latent.shape={current_latent.shape}")

        Returns a small modulation tensor (slow / attractor / long-term voice) to be added
        to the main hidden. This is the ONLY remaining external Python touchpoint for the
        slow brain components.

        When chunked_slow_adapter is active + internal fast recurrence is strong,
        this method becomes extremely cheap (mostly reads from already-committed slow memory).

        This is the key mechanism that lets the fast path (FastGatedLinearRecurrence) stay
        almost completely inside the compiled block while still receiving the "slow thinker" signal.
        """
        if getattr(self, '_light_eval_mode', False) or getattr(self, '_long_term_write_disabled', False):
            return None

        try:
            device = current_latent.device
            dtype = current_latent.dtype

            # === Robustness for native batched 72 + internal FastGated (Option A / D-implementation path) ===
            # When fast recurrence is the primary per-micro citizen (Griffin-style), the slow injection
            # must never produce shape errors that kill the measurement. Normalize aggressively in light/inference modes.
            is_light = getattr(self, '_light_eval_mode', False) or getattr(self, '_native_eval_mode', False) or inference_mode

            # Use chunked slow adapter for reads if available (best state path)
            slow_mod = None
            if (self.chunked_slow_adapter is not None and
                getattr(self, 'chunked_slow_enabled', False) and
                not getattr(self, 'chunked_slow_ablation_zero', False)):

                pooled = current_latent.mean(dim=1) if current_latent.dim() == 3 else current_latent
                if is_light:
                    # Extra guard: ensure 2D for light read in batched native measurement
                    if pooled.dim() > 2:
                        pooled = pooled.squeeze()
                    if pooled.dim() == 1:
                        pooled = pooled.unsqueeze(0)
                slow_mod = self.chunked_slow_adapter.light_read(pooled)

            elif (self.long_term_memory is not None and
                  getattr(self, 'long_term_memory_enabled', False) and
                  not getattr(self, 'long_term_memory_ablation_zero', False)):

                pooled = current_latent.mean(dim=1) if current_latent.dim() == 3 else current_latent
                if is_light and pooled.dim() > 2:
                    pooled = pooled.squeeze()
                try:
                    read_signal, _, _ = self.long_term_memory(query=pooled)
                    slow_mod = read_signal
                except Exception:
                    slow_mod = None

            if slow_mod is None:
                return None

            # Small learned influence (kept for training signal)
            if slow_mod.dim() == 2:
                proj = slow_mod
            else:
                proj = slow_mod.mean(dim=1) if slow_mod.dim() == 3 else slow_mod

            influence = torch.sigmoid(self.long_term_read_influence(proj))
            weight = 0.15 + 0.1 * influence  # conservative in best-state config

            # In inference mode we can be even lighter (the internal fast recurrence + cached slow does most work)
            if inference_mode:
                weight = weight * 0.6

            modulation = slow_mod * weight.unsqueeze(-1) if slow_mod.dim() == 2 else slow_mod * weight.unsqueeze(-1).unsqueeze(-1)

            # Final attractor stabilization pull (very cheap)
            if hasattr(self, 'attractor') and not inference_mode:
                try:
                    attractor_pull = self.attractor(current_latent)
                    modulation = modulation + 0.08 * attractor_pull
                except Exception:
                    pass

            return modulation

        except Exception:
            return None

    def _get_long_term_summary(self, long_term_read: Optional[torch.Tensor], surprise: Optional[torch.Tensor] = None) -> Optional[torch.Tensor]:
        """
        Produce a compact summary from the long-term memory read that can be injected
        into the final one-body latent. Surprise (if present) modulates the strength
        of this summary so the LM head "feels" how novel/salient the slow memory content is.
        """
        if long_term_read is None:
            return None
        summary = long_term_read
        if surprise is not None:
            # Surprise amplifies the long-term summary's voice on the final readout
            s = surprise.mean() if surprise.dim() > 0 else surprise
            strength = torch.sigmoid(s) * 0.6 + 0.4
            summary = summary * strength
        return summary

    def enable_long_term_surprise_driven_memory(self, num_slots: int = 64, top_k: int = 12):
        """
        Clean one-liner to activate the full multi-scale memory system (fast thinker + surprise-driven long-term sparse memory).

        This creates a first-class `SparseGatedLongTermMemory` (Raven + LM2 + MSA 2026 + Titans surprise)
        and wires it so that Predictive Data Intuition surprise strongly influences both what is read from
        and what gets consolidated into long-term memory.
        """
        from .sparse_gated_long_term_memory import SparseGatedLongTermMemory

        ltm = SparseGatedLongTermMemory(
            d_model=self.d_model,
            num_slots=num_slots,
            top_k=top_k,
            use_gated_update=True,
            use_surprise=True,
        )

        self.attach_long_term_memory(ltm, enabled=True)

        # Best-state convenience: when enabling long-term, also offer to enable chunked slow by default
        # (can be disabled later via set_chunked_slow_ablation)
        if not getattr(self, 'chunked_slow_ablation_zero', False):
            try:
                self.enable_chunked_slow_memory(long_term_memory=ltm, chunk_size=8)
            except Exception:
                pass  # non-fatal

        return ltm

    # === Best-State v2: Chunked Slow Memory (LaCT + ATLAS Omega) ===
    def attach_chunked_slow_adapter(self, adapter, enabled: bool = True):
        """
        Attach a ChunkedSlowMemoryAdapter.
        When active, long-term memory writes are no longer per-micro or small-stride,
        but accumulated and committed in coherent chunks (size or surprise-triggered).
        This is the key architectural move for practical slow-path efficiency.
        """
        self.chunked_slow_adapter = adapter
        self.chunked_slow_enabled = bool(enabled)
        if adapter is not None:
            adapter.set_ablation(enabled=enabled, ablation_zero=self.chunked_slow_ablation_zero)

    def enable_chunked_slow_memory(self, long_term_memory=None, chunk_size: int = 8, use_surprise_trigger: bool = True):
        """
        One-liner to activate the chunked slow memory path (highest-impact remaining piece
        toward Hybrid Brain-Mimetic Recurrence v2).

        If long_term_memory is None, it will try to use the already attached self.long_term_memory.
        """
        from .chunked_slow_memory_adapter import ChunkedSlowMemoryAdapter

        ltm = long_term_memory or self.long_term_memory
        if ltm is None:
            # Auto-create a minimal long-term memory if none exists
            from .sparse_gated_long_term_memory import SparseGatedLongTermMemory
            ltm = SparseGatedLongTermMemory(d_model=self.d_model, num_slots=64, top_k=12)
            self.attach_long_term_memory(ltm, enabled=True)

        adapter = ChunkedSlowMemoryAdapter(
            long_term_memory=ltm,
            chunk_size=chunk_size,
            use_surprise_trigger=use_surprise_trigger,
            ablation_zero=self.chunked_slow_ablation_zero,
        )
        self.attach_chunked_slow_adapter(adapter, enabled=True)
        return adapter

    def set_chunked_slow_ablation(self, enabled: bool = True, ablation_zero: bool = False):
        self.chunked_slow_enabled = enabled and not ablation_zero
        self.chunked_slow_ablation_zero = ablation_zero
        if self.chunked_slow_adapter is not None:
            self.chunked_slow_adapter.set_ablation(enabled=enabled, ablation_zero=ablation_zero)

    def _stabilize_attractor(
        self,
        current_attractor: torch.Tensor,
        attractor_history: torch.Tensor,
        depth: int,
        long_term_context: Optional[torch.Tensor] = None,
        surprise: Optional[torch.Tensor] = None,
    ) -> torch.Tensor:
        """
        Slow stabilization layer (StabilizingAttractorMemory) now explicitly multi-scale.

        long_term_context (from surprise-modulated SparseGatedLongTermMemory read)
        + surprise (PredictiveDataIntuition) bias the direction and strength of the
        attractor pull. This is the "slow thinker" feeling the long-term memory and
        data intuition -- completing the central surprise coupling loop.

        High surprise -> stronger long-term memory influence on the basin the attractor
        stabilizes toward. This is the brain-mimetic "slow consolidation" path.
        """
        history = attractor_history

        if long_term_context is not None:
            lt_weight = 0.18
            if surprise is not None:
                # Surprise amplifies long-term's voice in the slow stabilization
                surprise_mod = torch.sigmoid(surprise.mean()) * 0.15
                lt_weight += surprise_mod

            # Long-term context participates in shaping the attractor target
            history = history + long_term_context * lt_weight

        # Delegate the actual dynamics to the existing attractor module (keeps it One-Body clean)
        return self.attractor(current_attractor, history=history, depth=depth)

    def init_state(self, batch_size: int, device: torch.device, dtype: torch.dtype) -> TripleMemoryState:
        return TripleMemoryState(
            working_memory=torch.zeros(batch_size, self.working.n_streams, self.d_model, device=device, dtype=dtype),
            attractor_state=torch.zeros(batch_size, self.d_model, device=device, dtype=dtype),
            provenance_register=torch.zeros(batch_size, self.d_model, device=device, dtype=dtype),
            step_count=torch.zeros(batch_size, device=device, dtype=torch.long),
        )


# =============================================================================
# Brain-Mimetic Improvement of GRAM/PTRM Stochastic Breadth
# =============================================================================

class BrainMimeticStochasticSampler(nn.Module):
    """
    Brain-inspired reinterpretation and improvement of historical GRAM/PTRM stochastic breadth.

    Old GRAM/PTRM:
    - Add learned prior/posterior noise to high-level latent (z_h) during recurrence.
    - Generate K trajectories and (sometimes) select among them.
    - This was a strong inductive bias historically (contributed to 5.53~5.56 signals).

    Brain-mimetic redefinition:
    - Multiple parallel "mental simulations" or "draft thoughts" running inside Working Memory
      (exactly the multi-stream ActiveWorkingMemory we defined above).
    - Stochastic sampling is not blind noise -- it is **structured hypothesis generation**
      modulated by the current state of the other two memory systems:
        - AttractorMemory: favors trajectories that lead toward stable/good attractors.
        - ProvenanceMemory: favors trajectories that are causally grounded and consistent.
    - This turns generic stochastic breadth into something closer to:
      "The brain running several what-if simulations in working memory, stabilized by cortical attractors, and filtered by hippocampal source monitoring."

    This is no longer "add noise to the latent vector".
    It is "sample and evolve multiple active thoughts inside the memory system itself".
    """

    def __init__(self, d_model: int, n_trajectories: int = 4):
        super().__init__()
        self.d_model = d_model
        self.n_trajectories = n_trajectories

        # Simple learned prior for generating variation (can be upgraded to full prior/posterior later)
        self.trajectory_prior = nn.Sequential(
            RMSNorm(d_model),
            nn.Linear(d_model, d_model * 2),
            nn.GELU(),
            nn.Linear(d_model * 2, d_model),
        )

        # How much each memory component modulates the sampling
        self.attractor_modulation = nn.Linear(d_model, 1)
        self.provenance_modulation = nn.Linear(d_model, 1)

        # Learned trajectory scorer (brain-like evidence accumulation)
        # Instead of pure heuristic, a small module that scores trajectories
        # based on combined attractor stability + provenance grounding + internal coherence
        self.trajectory_scorer = nn.Sequential(
            RMSNorm(d_model * 3),
            nn.Linear(d_model * 3, d_model),
            nn.GELU(),
            nn.Linear(d_model, 1),
        )

    def _ensure_same_device(self, tensor: torch.Tensor):
        """Same device sync helper as in the TripleMemory (prevents cuda/cpu crashes)."""
        device = tensor.device
        dtype = tensor.dtype
        if next(self.parameters()).device != device:
            self.to(device=device, dtype=dtype)

    def sample_trajectories(
        self,
        current_working_memory: torch.Tensor,   # (B, n_streams, d)
        attractor_state: torch.Tensor,          # (B, d)
        provenance_state: torch.Tensor,         # (B, d)
        k: int = None,
        long_term_context: Optional[torch.Tensor] = None,  # (B, d) -- from long-term memory, surprise-modulated
    ) -> torch.Tensor:
        # Always sync first -- critical for not crashing the diagnostic with device errors
        self._ensure_same_device(current_working_memory)

        device = current_working_memory.device
        dtype = current_working_memory.dtype

        current_working_memory = current_working_memory.to(device=device, dtype=dtype)
        attractor_state = attractor_state.to(device=device, dtype=dtype)
        provenance_state = provenance_state.to(device=device, dtype=dtype)
        """
        Generate K structured trajectory variations inside working memory space,
        biased by attractor stability, provenance grounding, **and long-term memory context**.

        When long_term_context is provided (from SparseGatedLongTermMemory + surprise),
        trajectories are generated with awareness of relevant long-term memory.
        This is a key part of making mental simulations multi-scale and data-intuition aware.
        """
        k = k or self.n_trajectories
        b, n_streams, d = current_working_memory.shape

        # Base representation from current working memory
        base = current_working_memory.mean(dim=1)  # (B, d)

        # Learned variation (prior-like)
        variation = self.trajectory_prior(base) * 0.1  # small scale like old stochastic

        # Attractor bias
        attractor_bias = torch.sigmoid(self.attractor_modulation(attractor_state)) * 0.15
        attractor_pull = attractor_state.unsqueeze(1) * attractor_bias.unsqueeze(-1).unsqueeze(-1)

        # Provenance bias
        provenance_bias = torch.sigmoid(self.provenance_modulation(provenance_state)) * 0.12
        provenance_pull = provenance_state.unsqueeze(1) * provenance_bias.unsqueeze(-1).unsqueeze(-1)

        # Long-term memory bias (new, surprise-modulated from the long-term layer)
        long_term_bias = 0.0
        if long_term_context is not None:
            long_term_context = long_term_context.to(device, dtype)
            # When the model has pulled relevant long-term memory (often driven by surprise),
            # we bias some trajectories toward that long-term context. Keep (B, d)
            long_term_bias = long_term_context * 0.18

        # Generate K slightly different trajectories
        trajectories = []
        for i in range(k):
            noise = torch.randn_like(base) * 0.05
            traj = base + variation + noise          # (B, d)
            # Add attractor/provenance bias per trajectory
            a_mix = 0.5 + 0.5 * (i / max(k-1, 1))
            p_mix = 0.3 + 0.7 * (i / max(k-1, 1))
            traj = traj + attractor_state * a_mix * 0.15
            traj = traj + provenance_state * p_mix * 0.12

            # Long-term context bias (stronger on some trajectories)
            if long_term_context is not None:
                lt_mix = 0.2 + 0.6 * (i / max(k-1, 1))
                traj = traj + long_term_bias * lt_mix

            trajectories.append(traj)

        # Stack as (B, K, d)
        stacked = torch.stack(trajectories, dim=1)
        return stacked

    def select_best_trajectory(
        self,
        trajectories: torch.Tensor,             # (B, K, d)
        attractor_state: torch.Tensor,
        provenance_state: torch.Tensor,
        intuition_surprise: torch.Tensor = None,   # (B, K) - optional data intuition surprise
        long_term_context: Optional[torch.Tensor] = None,  # (B, d) - long-term memory context
    ) -> torch.Tensor:
        """
        Brain-like selection using learned scorer + structural signals + data intuition surprise
        + long-term memory context.

        When long_term_context is provided, trajectories that align well with relevant long-term memory
        (especially when combined with high surprise) get an additional boost.
        """
        # Sync first
        self._ensure_same_device(trajectories)

        b, k, d = trajectories.shape

        device = trajectories.device
        dtype = trajectories.dtype
        trajectories = trajectories.to(device=device, dtype=dtype)
        attractor_state = attractor_state.to(device=device, dtype=dtype)
        provenance_state = provenance_state.to(device=device, dtype=dtype)

        # Core structural scores
        attr_align = -torch.norm(trajectories - attractor_state.unsqueeze(1), dim=-1)          # (B, K)
        prov_consist = torch.sum(trajectories * provenance_state.unsqueeze(1), dim=-1)          # (B, K)
        traj_mean = trajectories.mean(dim=1, keepdim=True)
        coherence = -torch.norm(trajectories - traj_mean, dim=-1)                               # (B, K)

        # Base score (structural)
        base_score = (attr_align * 0.42 + prov_consist * 0.33 + coherence * 0.25)

        # Data Intuition Surprise boost
        if intuition_surprise is not None:
            intuition_surprise = intuition_surprise.to(device=device, dtype=dtype)
            # data_intuition currently returns per-batch surprise (not yet per-trajectory);
            # broadcast across K so the current "surprise level" can still modulate selection
            if intuition_surprise.dim() == 1:
                # Defensive expand for variable K (light mode forces K=1)
                effective_k = k if 'k' in locals() else 1
                intuition_surprise = intuition_surprise.unsqueeze(1).expand(-1, effective_k)
            elif intuition_surprise.dim() == 2 and intuition_surprise.size(1) != (k if 'k' in locals() else intuition_surprise.size(1)):
                effective_k = k if 'k' in locals() else intuition_surprise.size(1)
                intuition_surprise = intuition_surprise.mean(dim=1, keepdim=True).expand(-1, effective_k)
            surprise_norm = torch.sigmoid(intuition_surprise)
            surprise_boost = surprise_norm * 0.28
            base_score = base_score + surprise_boost

        # Long-term memory alignment boost (new)
        if long_term_context is not None:
            long_term_context = long_term_context.to(device, dtype)
            lt_align = torch.sum(trajectories * long_term_context.unsqueeze(1), dim=-1)  # (B, K)
            # Modest but meaningful boost for trajectories consistent with long-term memory
            long_term_boost = lt_align * 0.18
            base_score = base_score + long_term_boost

        final_score = base_score

        # Pick best trajectory
        best_idx = torch.argmax(final_score, dim=1)
        best_traj = trajectories[torch.arange(b), best_idx]

        return best_traj

"""
# Force-close any leaked triple-quoted string from previous corruption
"""


def integrate_brain_mimetic_stochastic_into_triple_memory(
    triple_memory: BrainMimeticTripleMemory,
    k: int = 4,
    ablation_zero: bool = False
):
    """Helper to attach BrainMimeticStochasticSampler to TripleMemory (GRAM/PTRM style)."""
    if ablation_zero:
        triple_memory.stochastic_sampler = None
        return triple_memory
    sampler = BrainMimeticStochasticSampler(triple_memory.d_model, n_trajectories=k)
    triple_memory.stochastic_sampler = sampler
    triple_memory.stochastic_k = k
    triple_memory._stochastic_ablation_zero = False
    triple_memory.k = k
    return triple_memory
